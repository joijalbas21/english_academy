<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.englishacademy.controllers.profesores.ProfesorRegistroViewController"
            style="-fx-background-color: #0f1419;">

    <left>
        <fx:include source="../shared/menu-sidebar.fxml" />
    </left>

    <center>
        <VBox style="-fx-padding: 30;" spacing="20">
            <Label fx:id="tituloLabel" style="-fx-font-size: 24; -fx-text-fill: #ffffff; -fx-font-weight: bold;" />

            <GridPane hgap="15" vgap="15" style="-fx-padding: 20;">
                <columnConstraints>
                    <javafx.scene.layout.ColumnConstraints prefWidth="150" />
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Nombre:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="nombreField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Apellido:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="apellidoField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="DNI:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="dniField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Email:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </GridPane>

            <Label fx:id="errorLabel" style="-fx-text-fill: #ff6b6b; -fx-font-weight: bold;" />

            <HBox spacing="10" style="-fx-padding: 20 0 0 0;">
                <Button text="Guardar" onAction="#handleGuardar"
                        style="-fx-padding: 10 30; -fx-background-color: #00d4d4; -fx-text-fill: #0f1419; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button text="Cancelar" onAction="#handleCancelar"
                        style="-fx-padding: 10 30; -fx-background-color: #666666; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
