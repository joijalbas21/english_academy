<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.englishacademy.controllers.cursos.CursoRegistroViewController"
            style="-fx-background-color: #0f1419;">

    <left>
        <fx:include source="../shared/menu-sidebar.fxml" />
    </left>

    <center>
        <VBox style="-fx-padding: 30;" spacing="20">
            <Label fx:id="tituloLabel" style="-fx-font-size: 24; -fx-text-fill: #ffffff; -fx-font-weight: bold;" />

            <GridPane hgap="15" vgap="15" style="-fx-padding: 20;">
                <columnConstraints>
                    <javafx.scene.layout.ColumnConstraints prefWidth="150" />
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Nombre:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="nombreField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Nivel:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ComboBox fx:id="nivelCombo" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Ciclo Lectivo:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="cicloCombo" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Día de Semana:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <ComboBox fx:id="diaCombo" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Hora Inicio (HH:mm):" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="horaInicioField" GridPane.columnIndex="1" GridPane.rowIndex="4" promptText="14:30" />

                <Label text="Hora Fin (HH:mm):" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <TextField fx:id="horaFinField" GridPane.columnIndex="1" GridPane.rowIndex="5" promptText="15:30" />

                <Label text="Aula:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <ComboBox fx:id="aulaCombo" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                <Label text="Descripción:" style="-fx-text-fill: #ffffff;" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                <TextArea fx:id="descripcionField" wrapText="true" prefRowCount="5" GridPane.columnIndex="1" GridPane.rowIndex="7" />
            </GridPane>

            <Label fx:id="errorLabel" style="-fx-text-fill: #ff6b6b; -fx-font-weight: bold;" />

            <HBox spacing="10" style="-fx-padding: 20 0 0 0;">
                <Button text="Guardar" onAction="#handleGuardar"
                        style="-fx-padding: 10 30; -fx-background-color: #00d4d4; -fx-text-fill: #0f1419; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button text="Cancelar" onAction="#handleCancelar"
                        style="-fx-padding: 10 30; -fx-background-color: #666666; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
