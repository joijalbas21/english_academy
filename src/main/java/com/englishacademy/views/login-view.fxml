<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.englishacademy.controllers.LoginViewController"
            style="-fx-background-color: #0f1419;">
    <center>
        <VBox alignment="CENTER" spacing="30" style="-fx-padding: 40;">
            <ImageView fitHeight="50" fitWidth="120" preserveRatio="true">
                <image>
                    <Image url="file:./src/main/resources/assets/logo-dark.png" />
                </image>
            </ImageView>

            <VBox alignment="CENTER" spacing="10">
                <Label text="Bienvenido" style="-fx-font-size: 32; -fx-text-fill: #ffffff; -fx-font-weight: bold;" />
                <Label text="Ingresá tus credenciales para continuar" style="-fx-font-size: 13; -fx-text-fill: #888888;" />
            </VBox>

            <VBox spacing="8">
                <Label text="Email" style="-fx-text-fill: #00d4d4; -fx-font-size: 12;" />
                <TextField fx:id="emailField" style="-fx-control-inner-background: #1a1f27; -fx-text-fill: #ffffff; -fx-border-color: #00d4d4; -fx-border-width: 1; -fx-padding: 12; -fx-font-size: 12;"
                           promptText="tu@email.com" />
            </VBox>

            <VBox spacing="8">
                <Label text="Contraseña" style="-fx-text-fill: #00d4d4; -fx-font-size: 12;" />
                <PasswordField fx:id="passwordField" style="-fx-control-inner-background: #1a1f27; -fx-text-fill: #ffffff; -fx-border-color: #00d4d4; -fx-border-width: 1; -fx-padding: 12; -fx-font-size: 12;"
                               promptText="••••••••" />
            </VBox>

            <Button text="INGRESAR" style="-fx-padding: 14; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-color: #00d4d4; -fx-text-fill: #0f1419; -fx-cursor: hand;"
                    onAction="#handleLogin" />

            <Label text="o continúa con" style="-fx-text-fill: #666666; -fx-font-size: 11;" alignment="CENTER" />

            <HBox alignment="CENTER" spacing="10">
                <Button text="CONTINUAR CON GOOGLE" style="-fx-padding: 12 20; -fx-border-color: #333333; -fx-border-width: 1; -fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 12; -fx-font-weight: bold; -fx-cursor: not-allowed; -fx-opacity: 0.6;"
                        mouseTransparent="false">
                    <tooltip>
                        <Tooltip text="Fuera del Scope del proyecto" style="-fx-font-size: 11; -fx-text-fill: #ff6b6b;" />
                    </tooltip>
                </Button>
            </HBox>
        </VBox>
    </center>
</BorderPane>
